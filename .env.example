# Required
DATABASE_URL="file:./dev.db"

# Optional: most config can be set in the Settings UI instead.
# If set, these override values stored in the database.

# App URL (used for invite links in emails)
APP_URL="http://localhost:3000"

# Email provider: none | smtp | resend
EMAIL_PROVIDER="none"

# Required when EMAIL_PROVIDER=smtp
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER=""
# SMTP_PASS=""

# Required when EMAIL_PROVIDER=resend (get key from resend.com)
# RESEND_API_KEY="re_..."

# Required for both smtp and resend (e.g. "VyteKit <noreply@yourdomain.com>")
# EMAIL_FROM="noreply@yourdomain.com"

# Admin password is set on first run via /admin/setup (stored hashed in DB)

